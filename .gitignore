# .gitignore

# Environment
.env
.env.local
*.env

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
*.egg-info/
dist/
build/

# Terraform
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/

# Secrets
*.pem
*.key
secrets/

# Data
data/
*.csv
*.json
!package.json
!tsconfig.json

# Models (large files)
models/
*.bin
*.pt
*.onnx
