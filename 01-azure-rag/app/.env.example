# .env.example - Azure RAG Configuration
# Copy to .env and fill in your values

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://oai-swissrag.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://search-swissrag.search.windows.net
AZURE_SEARCH_API_KEY=your-search-key
AZURE_SEARCH_INDEX=documents

# Azure Storage
AZURE_STORAGE_ACCOUNT=stswissrag
AZURE_STORAGE_KEY=your-storage-key

# PostgreSQL (optional, for pgvector)
POSTGRESQL_HOST=psql-swissrag.postgres.database.azure.com
POSTGRESQL_DATABASE=ragdb
POSTGRESQL_USER=ragadmin
POSTGRESQL_PASSWORD=your-db-password
